rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(data) {
      return request.auth.uid in data.members;
    }

    match /users/{uid} {
      allow get: if isSignedIn()
        && request.auth.uid == uid;

      allow list: if isSignedIn();

      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'householdId',
          'displayName',
          'email',
          'pendingSplitNotifications',
        ])
        && request.resource.data.householdId is string
        && request.resource.data.householdId.size() > 0
        && request.resource.data.householdId.size() <= 20
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 150
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email;

      allow update: if isSignedIn()
        && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pendingSplitNotifications',
        ]);
    }

    match /households/{householdId} {
      allow read: if isSignedIn()
        && isMember(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'code',
          'members',
          'createdBy',
          'fixedExpenses',
          'months',
        ])
        && request.resource.data.code == householdId
        && request.resource.data.code is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid
        && request.resource.data.fixedExpenses is list
        && request.resource.data.fixedExpenses.size() == 0
        && request.resource.data.months is map;

      allow update: if isSignedIn()
        && isMember(resource.data)
        && request.resource.data.code == resource.data.code
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.members == resource.data.members
        && request.resource.data.fixedExpenses is list
        && request.resource.data.fixedExpenses.size() <= 200
        && request.resource.data.months is map;

      allow update: if isSignedIn()
        && !(request.auth.uid in resource.data.members)
        && request.resource.data.code == resource.data.code
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.fixedExpenses == resource.data.fixedExpenses
        && request.resource.data.months == resource.data.months
        && request.resource.data.members is list
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.auth.uid in request.resource.data.members;
    }

    match /splits/{splitId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participantUids;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantUids;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.status == resource.data.status;

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.createdBy
        && resource.data.status == 'open'
        && request.resource.data.status == 'closed';

      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.participantUids;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
